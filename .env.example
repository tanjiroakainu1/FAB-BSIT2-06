# Standalone app: no backend. All data is stored in browser localStorage.

# EmailJS – OTP for registration (email confirmation)
# Dashboard: https://dashboard.emailjs.com
# Public Key: use in frontend only. Private Key: do NOT put here (server-side only).
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
# Template ID: from EmailJS → Email Templates → One-Time Password
VITE_EMAILJS_TEMPLATE_ID=your_template_id

# 2nd OTP – same public key; only Service ID + Template ID differ.
VITE_EMAILJS_SERVICE_ID_2=your_service_id_2
VITE_EMAILJS_TEMPLATE_ID_2=your_template_id_2
